{
  "version": 2,
  "builds": [
    {
      "src": "essay.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/essay.html"
    },
    {
      "src": "/real_essay.html",
      "dest": "/public/real_essay.html"
    },
    {
      "src": "/style-1.css",
      "dest": "/public/style-1.css"
    },
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/script.js",
      "dest": "/script.js"
    }
  ]
}
